{
  "name": "shape-text",
  "version": "0.1.0",
  "description": "Browser-first TypeScript library for laying out text inside polygon shapes and rendering to SVG.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test"
  },
  "keywords": [
    "svg",
    "text-layout",
    "shape-text",
    "polygon",
    "typography"
  ],
  "author": "Admin",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}

